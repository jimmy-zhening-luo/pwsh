##############################
####    .editorconfig     ####
####  @version 01702.0.0  ####
##############################

#@doc https://editorconfig.org/
#@doc https://github.com/editorconfig/editorconfig-vscode?tab=readme-ov-file#supported-properties

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ics,cmd,bat,reg}]
end_of_line = crlf

[*.{txt,ini,csv,tsv}]
indent_style = unset

[*,{csv,tsv}]
indent_size = 4

[*.cs]
dotnet_analyzer_diagnostic.category-Style.severity = suggestion

#region Style/Format
#part IDE0055/dotnet
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
#endpart

#part IDE0055/C#/Line
csharp_new_line_before_open_brace = accessors, anonymous_methods, anonymous_types, control_blocks, events, indexers, lambdas, local_functions, methods, object_collection_array_initializers, properties, types
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true
csharp_new_line_between_query_expression_clauses = true
#endpart

#part IDE0055/C#/Indent
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = flush_left
csharp_indent_block_contents = true
csharp_indent_braces = false
csharp_indent_case_contents_when_block = true
#endpart

#part IDE0055/C#/Space
csharp_space_after_cast = false
csharp_space_after_keywords_in_control_flow_statements = true
csharp_space_between_parentheses = false
csharp_space_before_colon_in_inheritance_clause = true
csharp_space_after_colon_in_inheritance_clause = true
csharp_space_around_binary_operators = before_and_after
csharp_space_between_method_declaration_parameter_list_parentheses = false
csharp_space_between_method_declaration_empty_parameter_list_parentheses = false
csharp_space_between_method_declaration_name_and_open_parenthesis = false
csharp_space_between_method_call_parameter_list_parentheses = false
csharp_space_between_method_call_empty_parameter_list_parentheses = false
csharp_space_between_method_call_name_and_opening_parenthesis = false
csharp_space_after_comma = true
csharp_space_before_comma = false
csharp_space_after_dot = false
csharp_space_before_dot = false
csharp_space_after_semicolon_in_for_statement = true
csharp_space_before_semicolon_in_for_statement = false
csharp_space_around_declaration_statements = false
csharp_space_before_open_square_brackets = false
csharp_space_between_empty_square_brackets = false
csharp_space_between_square_brackets = false
#endpart

#part IDE0055/C#/Wrap
csharp_preserve_single_line_statements = true
csharp_preserve_single_line_blocks = true
#endpart
#endregion


#region Style/Language
#part IDE0007-8
csharp_style_var_for_built_in_types = true
csharp_style_var_when_type_is_apparent = true
csharp_style_var_elsewhere = true
#endpart

#part IDE0021
csharp_style_expression_bodied_constructors = true
#endpart

#part IDE0022
csharp_style_expression_bodied_methods = true
#endpart

#part IDE0023-24
csharp_style_expression_bodied_operators = true
#endpart

#part IDE0025
csharp_style_expression_bodied_properties = true
#endpart

#part IDE0026
csharp_style_expression_bodied_indexers = true
#endpart

#part IDE0027
csharp_style_expression_bodied_accessors = true
#endpart

#part IDE0036
csharp_preferred_modifier_order = static, required, new, virtual, abstract, sealed, override, public, private, protected, internal, file, extern, readonly, unsafe, volatile, async
#endpart

#part IDE0040
dotnet_style_require_accessibility_modifiers = omit_if_default
#endpart

#part IDE0047-8
dotnet_style_parentheses_in_arithmetic_binary_operators = never_if_unnecessary
dotnet_style_parentheses_in_relational_binary_operators = never_if_unnecessary
dotnet_style_parentheses_in_other_binary_operators = never_if_unnecessary
dotnet_style_parentheses_in_other_operators = never_if_unnecessary
#endpart

#part IDE0061
csharp_style_expression_bodied_local_functions = true
#endpart

#part IDE0065
csharp_using_directive_placement = inside_namespace
#endpart

#part IDE0072
dotnet_diagnostic.IDE0072.severity = none
#endpart

#part IDE0160-1
dotnet_diagnostic.IDE0160.severity = none
dotnet_diagnostic.IDE0161.severity = none
csharp_style_namespace_declarations = file_scoped # file_scoped | block_scoped
#endpart

#part IDE2000
dotnet_style_allow_multiple_blank_lines_experimental = false
#endpart

#part IDE2001
csharp_style_allow_embedded_statements_on_same_line_experimental = true
#endpart

#part IDE2002
csharp_style_allow_blank_lines_between_consecutive_braces_experimental = false
#endpart

#part IDE2003
dotnet_style_allow_statement_immediately_after_block_experimental = false
#endpart

#part IDE2004
csharp_style_allow_blank_line_after_colon_in_constructor_initializer_experimental = false
#endpart

#part IDE2005
csharp_style_allow_blank_line_after_token_in_conditional_expression_experimental = false
#endpart

#part IDE2006
csharp_style_allow_blank_line_after_token_in_arrow_expression_clause_experimental = false
#endpart

#endregion

#region Quality
#endregion
